    "description": "A simple solution to use headers according to PSR-7.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://quillstack.com/headers/",
    "authors": [
        {
            "name": "Radek Ziemniewicz",
            "email": "open-source@quillstack.com"
        }
    ],
    "require": {
        "php": "^7.4",
        "psr/http-message": "^1.0"
